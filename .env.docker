# LLM — Primary (Gemini)
GEMINI_API_KEY=<your_gemini_api_key>
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# LLM — Fallback (Ollama)
OLLAMA_MODEL=qwen3:8b-q4_K_M
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Search
HOW_MANY_SEARCHES=3
RESULTS_PER_SEARCH=5
SEARXNG_BASE_URL=http://searxng:8080

# Email (optional — leave SENDGRID_API_KEY empty to save report to file instead)
SENDGRID_API_KEY=
MAILHOG_HOST=mailhog
MAILHOG_PORT=1025
FROM_EMAIL=deepforge@local.dev
TO_EMAIL=sanjay@local.dev

# Observability
SERVICE_NAME=deepforge
SERVICE_VERSION=0.1.0
LOG_LEVEL=info
OTLP_ENDPOINT=tempo:4318

# Pipeline
DEEPFORGE_QUERY=Latest AI agent frameworks in 2025